        "bodyType": "HTML",
        "body": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"></head><body style=\"margin:0;padding:0;background-color:#f4f4f4;font-family:'Segoe UI',Arial,Helvetica,sans-serif;\"><table cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;max-width:600px;margin:20px auto;background:#fff;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);\"><tr><td style=\"padding:32px 32px 0 32px;\"><table cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;\"><tr><td style=\"background-color:#ea580c;padding:20px;border-radius:8px 8px 0 0;text-align:center;\"><h1 style=\"color:#fff;margin:0;font-size:18px;font-weight:600;\">Cybersecurity: ASSESSMENT \u2014 SUSPICIOUS</h1></td></tr></table><p style=\"font-size:15px;color:#1a1a1a;margin-top:24px;margin-bottom:8px;\">Hello,</p><p style=\"font-size:15px;color:#1a1a1a;margin-top:0;margin-bottom:20px;\">Greetings!</p><p style=\"font-size:14px;color:#333;line-height:1.6;margin-bottom:16px;\">Upon applying heuristic and technical assessment to the forwarded email, this email is flagged as:</p><table cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;background-color:#fff7ed;border:2px solid #ea580c;border-radius:8px;margin-bottom:20px;\"><tr><td style=\"padding:16px 20px;text-align:center;\"><p style=\"font-size:28px;margin:0 0 4px 0;\">\u26a0\ufe0f</p><p style=\"font-size:16px;color:#9a3412;font-weight:600;margin:0;\">SUSPICIOUS</p><p style=\"font-size:13px;color:#9a3412;margin:4px 0 0 0;\">This email exhibits suspicious characteristics that warrant caution.</p></td></tr></table><p style=\"font-size:13px;color:#555;margin-bottom:4px;\"><strong>Threat Classification:</strong> {{ $('Parse AI Response').item.json.threat_classification }}</p><p style=\"font-size:13px;color:#555;margin-bottom:4px;\"><strong>Confidence Score:</strong> {{ $('Parse AI Response').item.json.confidence_score }}%</p><h2 style=\"font-size:15px;color:#9a3412;margin-top:24px;margin-bottom:12px;\">Indicators Detected</h2><ul style=\"font-size:14px;color:#333;line-height:1.8;padding-left:20px;margin-bottom:20px;\">{{ $('Parse AI Response').item.json.indicators.map(i => '<li>' + i + '</li>').join('') }}</ul><table cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;background-color:#fff7ed;border-left:4px solid #ea580c;margin-bottom:20px;\"><tr><td style=\"padding:16px 20px;\"><p style=\"font-size:14px;color:#333;line-height:1.6;margin:0;\">{{ $('Parse AI Response').item.json.operator_insights }}</p></td></tr></table><table cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;background-color:#fefce8;border-left:4px solid #ca8a04;margin-bottom:24px;\"><tr><td style=\"padding:12px 20px;\"><p style=\"font-size:14px;color:#333;margin:0;\"><strong>RECOMMENDATION:</strong> {{ $('Parse AI Response').item.json.recommendation }}</p></td></tr></table><p style=\"font-size:14px;color:#333;line-height:1.6;margin-bottom:16px;\">Thank you for your cooperation, time, and effort in this matter...</p><p style=\"font-size:14px;color:#333;margin-bottom:8px;\">Stay safe,</p><p style=\"font-size:14px;color:#333;margin-top:0;margin-bottom:4px;\"><strong>[Your Name]</strong></p><p style=\"font-size:13px;color:#555;margin-top:0;margin-bottom:4px;\">Cybersecurity Department</p><p style=\"font-size:13px;color:#555;margin-top:0;margin-bottom:4px;\">[Your Company]</p><p style=\"font-size:13px;color:#2563eb;margin-top:0;margin-bottom:16px;\"><a href=\"mailto:[yourname]@[company-domain].com\" style=\"color:#2563eb;\">[yourname]@[company-domain].com</a></p></td></tr></table></body></html>"
      }
